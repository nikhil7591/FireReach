# FireReach Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── REQUIRED ──────────────────────────────────────────────────
# Google Gemini API key (get one at https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# ── EMAIL SENDING (choose one, or leave both blank for preview-only) ─
# Option 1: Resend API (recommended — https://resend.com)
RESEND_API_KEY=your_resend_api_key_here

# The "from" address used in outbound emails
SENDER_EMAIL=onboarding@resend.dev

# Option 2: Gmail SMTP (use a Gmail App Password)
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=your_gmail_app_password

# ── OPTIONAL ───────────────────────────────────────────────────
# Set to true to skip real searches and use realistic mock data
DEMO_MODE=false
